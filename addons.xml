<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.redboxselector"
           name="RedBox Selector"
           version="1.1.1"
           provider-name="OpenAI Demo">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>

        <extension point="xbmc.python.pluginsource"
                   library="main.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>Search and launch content through another Kodi addon.</summary>
            <description>Forward searches to another installed Kodi addon.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
